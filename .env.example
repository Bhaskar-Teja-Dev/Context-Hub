# ContextHub Dashboard — Environment Variables (Example)
# Copy this file to .env.local and fill in your values
# Next.js reads .env.local automatically — never commit it to Git

# --------------------------------------------------
# Backend API URL
# For local development: http://localhost:8000
# For production (Render): RENDER_URL
# --------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
# ContextHub Backend — Environment Variables
# Copy this file to .env and fill in your actual values

# --------------------------------------------------
# Supabase (Database + Vector Search)
# --------------------------------------------------
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_KEY=YOU_SUPABASE_SERVICE_ROLE_KEY

# --------------------------------------------------
# Embedding Model (Local is preferred)
# --------------------------------------------------
EMBEDDING_MODEL_NAME=YOUR_MODEL_NAME

# --------------------------------------------------
# Server
# --------------------------------------------------
HOST=0.0.0.0
PORT=8000

# --------------------------------------------------
# Development Flags
# Set MOCK_EMBEDDINGS=true to skip loading the model
# and use a fast deterministic fallback (for quick testing)
# --------------------------------------------------
MOCK_EMBEDDINGS=false
